# ──────────────────────────────────────────────────
# Hermes + Pinto Chat – Docker Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────

# ══ จำเป็นต้องกรอก ════════════════════════════
# Pinto Bot ID — หาได้จาก Pinto Developer Console
# Used as first-start fallback only. After startup, durable value lives in
# hermes-config/config.yaml -> platforms.pinto.extra.botId (hermes-config/ is git-ignored).
PINTO_BOT_ID=

# ══ สร้างอัตโนมัติ (ไม่ต้องกรอก) ══════════════
# API Server Key — auto-generated on first run
# สร้างเอง: sh scripts/generate-api-key.sh
API_SERVER_KEY=

# ══ ไม่จำเป็น (ค่า default ใช้ได้เลย) ════════
# Docker Image
# Leave unset to use compose defaults:
# - docker-compose.yml => hermes-pinto:local
# - docker-compose.podman.yml => hermes-pinto:podman
# HERMES_IMAGE=hermes-pinto:local

# Pinto Adapter source (for Docker build)
PINTO_ADAPTER_REPO=https://github.com/fakduai-logistics-and-digital-platform/pinto-adapter-hermes.git
PINTO_ADAPTER_REF=main

# Hermes Gateway
HERMES_GATEWAY_PORT=8642
# Required for Podman port forwarding
API_SERVER_HOST=0.0.0.0

# Hermes Dashboard (Podman compose exposes this on 9119)
HERMES_DASHBOARD=1
HERMES_DASHBOARD_PORT=9119

TZ=Asia/Bangkok

# Pinto API (default = production)
# PINTO_API_URL=https://api.pinto-app.com

# Webhook
# If blank, container startup generates a random shared secret into hermes-config/.env.
# Same secret is reused for webhook, generating, and media upload unless overridden.
# PINTO_WEBHOOK_SECRET=
# PINTO_WEBHOOK_PATH=/plugins/pinto/webhook

# Public URL (set by configure-domain.sh)
PINTO_WEBHOOK_URL=http://127.0.0.1:8642/plugins/pinto/webhook

# Access Control
PINTO_ALLOW_ALL_USERS=true

# Cron / Notifications
# PINTO_HOME_CHANNEL=default-chat-id

# Optional: Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=***

# Optional: Hermes Model
# HERMES_MODEL=gpt-4o

# Allow any user to chat through configured platforms (testing/public webhook)
GATEWAY_ALLOW_ALL_USERS=true

# OpenAI-compatible inference provider (default example)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://45.136.254.176:20128/v1
HERMES_PROVIDER=openai-api
HERMES_MODEL=codex

# Optional: Nous Portal / Nemotron 3 Ultra free tier
# Requires `hermes setup --portal` login in the Hermes environment first.
# Free tier was announced as limited-time and requires exact `:free` model suffix.
# HERMES_PROVIDER=nous
# HERMES_MODEL=nvidia/nemotron-3-ultra:free
# Optional: OpenAI-compatible image generation endpoint
# Keep real keys only in .env. Do not commit secrets.
OPENAI_IMAGE_API_KEY=your_image_api_key_here
OPENAI_IMAGE_BASE_URL=http://your-ai-server:port/v1
OPENAI_IMAGE_API_MODEL=your_image_model_name
OPENAI_IMAGE_MODEL=custom
# Optional: upload generated images to free public hosts before sending link to Pinto.
# Values: catbox,litterbox,0x0,uguu,tmpfiles, auto/free/all, or blank to use the local tunnel media route.
# Comma-separated values are tried in order.
PINTO_MEDIA_UPLOAD_PROVIDER=catbox,litterbox,0x0,uguu,tmpfiles
# Set true only if Pinto bot receive endpoint supports media_url. Default false sends URL in text only.
PINTO_SEND_MEDIA_URL_FIELD=false
# Litterbox expiry options: 1h, 12h, 24h, 72h
PINTO_LITTERBOX_EXPIRY=24h

# Optional: Pinto bot_generating indicator endpoint.
# Hermes calls this while processing, then clears it before sending the reply.
PINTO_GENERATING_PATH=/v1/bots/webhook/generating
# Leave empty to reuse PINTO_WEBHOOK_SECRET. Startup auto-fills this in hermes-config/.env.
PINTO_GENERATING_SECRET=
# Default type for Hermes text generation. Image sends can override to image when media is present.
PINTO_GENERATING_TYPE=text

# Optional: upload local generated images to Pinto as multipart binary.
PINTO_RECEIVE_MEDIA_PATH=/v1/bots/webhook/receive-media
# Leave empty to reuse PINTO_WEBHOOK_SECRET. Startup auto-fills this in hermes-config/.env.
# Sends as X-Pinto-Media-Secret.
PINTO_MEDIA_UPLOAD_SECRET=

# Optional fallback: send throttled status messages as chat text.
# Leave blank when Pinto bot_generating websocket UI is enabled.
PINTO_TYPING_STATUS_MESSAGE=
PINTO_TYPING_STATUS_INTERVAL=8

# Optional: Hermes company workflow artifacts.
# When true, each new Pinto company workflow clears files under COMPANY_PROJECTS_DIR first,
# so /Users/.../company-projects shows only the latest generated project.
COMPANY_PROJECTS_DIR=/company-projects
CLEAR_COMPANY_PROJECTS_ON_WORKFLOW_START=true

