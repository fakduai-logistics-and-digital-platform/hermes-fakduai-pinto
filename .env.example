# ──────────────────────────────────────────────────
# Hermes + Pinto Chat – Docker Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────

# ══ จำเป็นต้องกรอก ════════════════════════════
# Pinto Bot ID — หาได้จาก Pinto Developer Console
PINTO_BOT_ID=

# ══ สร้างอัตโนมัติ (ไม่ต้องกรอก) ══════════════
# API Server Key — auto-generated on first run
# สร้างเอง: sh scripts/generate-api-key.sh
API_SERVER_KEY=

# ══ ไม่จำเป็น (ค่า default ใช้ได้เลย) ════════
# Docker Image
# Leave unset to use compose defaults:
# - docker-compose.yml => hermes-pinto:local
# - docker-compose.podman.yml => hermes-pinto:podman
# HERMES_IMAGE=hermes-pinto:local

# Pinto Adapter source (for Docker build)
PINTO_ADAPTER_REPO=https://github.com/fakduai-logistics-and-digital-platform/pinto-adapter-hermes.git
PINTO_ADAPTER_REF=main

# Hermes Gateway
HERMES_GATEWAY_PORT=8642
# Required for Podman port forwarding
API_SERVER_HOST=0.0.0.0

# Hermes Dashboard (Podman compose exposes this on 9119)
HERMES_DASHBOARD=1
HERMES_DASHBOARD_PORT=9119

TZ=Asia/Bangkok

# Pinto API (default = production)
# PINTO_API_URL=https://api.pinto-app.com

# Webhook
# PINTO_WEBHOOK_SECRET=
# PINTO_WEBHOOK_PATH=/plugins/pinto/webhook
# Optional Pinto JWT. Enables native chat API, real typing indicator, and binary image upload.
# PINTO_BEARER_TOKEN=

# Public URL (set by configure-domain.sh)
PINTO_WEBHOOK_URL=http://127.0.0.1:8642/plugins/pinto/webhook

# Access Control
PINTO_ALLOW_ALL_USERS=true

# Cron / Notifications
# PINTO_HOME_CHANNEL=default-chat-id

# Optional: Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=***

# Optional: Hermes Model
# HERMES_MODEL=gpt-4o

# Allow any user to chat through configured platforms (testing/public webhook)
GATEWAY_ALLOW_ALL_USERS=true

# OpenAI-compatible inference provider
OPENAI_API_KEY=
OPENAI_BASE_URL=http://45.136.254.176:20128/v1
HERMES_PROVIDER=openai-api
HERMES_MODEL=codex
# Optional: OpenAI-compatible image generation endpoint
# Keep real keys only in .env. Do not commit secrets.
OPENAI_IMAGE_API_KEY=your_image_api_key_here
OPENAI_IMAGE_BASE_URL=http://your-ai-server:port/v1
OPENAI_IMAGE_API_MODEL=your_image_model_name
OPENAI_IMAGE_MODEL=custom
# Optional: send throttled status messages when Pinto has no native typing indicator
PINTO_TYPING_STATUS_MESSAGE=Processing, please wait...
PINTO_TYPING_STATUS_INTERVAL=20

