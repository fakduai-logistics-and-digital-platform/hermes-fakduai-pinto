# ──────────────────────────────────────────────────
# Hermes + Pinto Chat – Docker Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────

# ══ จำเป็นต้องกรอก ════════════════════════════
# Pinto Bot ID — หาได้จาก Pinto Developer Console
PINTO_BOT_ID=

# ══ สร้างอัตโนมัติ (ไม่ต้องกรอก) ══════════════
# API Server Key — auto-generated on first run
# สร้างเอง: sh scripts/generate-api-key.sh
API_SERVER_KEY=

# ══ ไม่จำเป็น (ค่า default ใช้ได้เลย) ════════
# Docker Image
HERMES_IMAGE=hermes-pinto:local

# Pinto Adapter source (for Docker build)
PINTO_ADAPTER_REPO=https://github.com/fakduai-logistics-and-digital-platform/pinto-adapter-hermes.git
PINTO_ADAPTER_REF=main

# Hermes Gateway
HERMES_GATEWAY_PORT=8642
TZ=Asia/Bangkok

# Pinto API (default = production)
# PINTO_API_URL=https://api.pinto-app.com

# Webhook
# PINTO_WEBHOOK_SECRET=
# PINTO_WEBHOOK_PATH=/plugins/pinto/webhook

# Public URL (set by configure-domain.sh)
PINTO_WEBHOOK_URL=http://127.0.0.1:8642/plugins/pinto/webhook

# Access Control
PINTO_ALLOW_ALL_USERS=true

# Cron / Notifications
# PINTO_HOME_CHANNEL=default-chat-id

# Optional: Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=***

# Optional: Hermes Model
# HERMES_MODEL=gpt-4o
